    "dilemma": {
        "number": "\ub51c\ub808\ub9c8",
        "lightSide": "\uc120\ud55c \uc120\ud0dd",
        "darkSide": "\uc5b4\ub450\uc6b4 \uc120\ud0dd"
    },
    "dilemmas": {
        "d1": {
            "scenario": "\ub2f9\uc2e0\uc740 \ud68c\uc0ac\uc758 \uc2e0\uc785\uc0ac\uc6d0 \uba74\uc811\uad00\uc785\ub2c8\ub2e4. \ub2f9\uc2e0\ubcf4\ub2e4 \ub2a5\ub825\uc774 \ub6f0\uc5b4\ub09c \uc9c0\uc6d0\uc790\uac00 \uc788\uc9c0\ub9cc, \uc774 \uc0ac\ub78c\uc774 \ud569\uaca9\ud558\uba74 \ub2f9\uc2e0\uc758 \uc9c0\uc704\uac00 \uc704\ud611\ubc1b\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",
            "left": "\uacf5\uc815\ud558\uac8c \ud3c9\uac00\ud558\uace0 \ub2a5\ub825 \uc788\ub294 \uc0ac\ub78c\uc744 \ucd94\ucc9c\ud55c\ub2e4",
            "right": "\uc0ac\uc18c\ud55c \ub2e8\uc810\uc744 \uacfc\uc7a5\ud574 \ud0c8\ub77d\uc2dc\ud0a4\uace0 \ub0b4 \uc9c0\uc704\ub97c \uc9c0\ud0a8\ub2e4"
        },
        "d2": {
            "scenario": "\uce5c\ud55c \uce5c\uad6c\uac00 \ub2f9\uc2e0\uc5d0\uac8c \ud070 \ube44\ubc00\uc744 \ud138\uc5b4\ub193\uc558\uc2b5\ub2c8\ub2e4. \uc774 \uc815\ubcf4\ub97c \uc774\uc6a9\ud558\uba74 \uc9c1\uc7a5\uc5d0\uc11c \uc2b9\uc9c4\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",
            "left": "\ube44\ubc00\uc744 \ucca0\uc800\ud788 \uc9c0\ud0a4\uace0 \uce5c\uad6c\uc758 \uc2e0\ub8b0\ub97c \uc874\uc911\ud55c\ub2e4",
            "right": "\uc740\uadfc\ud788 \uc815\ubcf4\ub97c \ud65c\uc6a9\ud574 \uc2b9\uc9c4 \uae30\ud68c\ub97c \ub9cc\ub4e0\ub2e4"
        },
        "d3": {
            "scenario": "\ubb34\uc778 \uc790\ub3d9\ucc28\uac00 \uace0\uc7a5\ub098 5\uba85\uc744 \ud5a5\ud574 \ub2ec\ub9ac\uace0 \uc788\uc2b5\ub2c8\ub2e4. \ubc84\ud2bc\uc744 \ub204\ub974\uba74 \ucc28\ub97c \ub3cc\ub9b4 \uc218 \uc788\uc9c0\ub9cc, \ub2e4\ub978 1\uba85\uc774 \ub2e4\uce69\ub2c8\ub2e4.",
            "left": "\uc544\ubb34\uac83\ub3c4 \ud558\uc9c0 \uc54a\ub294\ub2e4. \uc9c1\uc811 \uc190\uc744 \ub354\ub7fd\ud788\uc9c0 \uc54a\ub294\ub2e4",
            "right": "\ubc84\ud2bc\uc744 \ub204\ub978\ub2e4. 1\uba85\uc758 \ud76c\uc0dd\uc73c\ub85c 5\uba85\uc744 \uc0b4\ub9b0\ub2e4"
        },
        "d4": {
            "scenario": "\ub2f9\uc2e0\uc758 \ud300\uc774 \ud070 \ud504\ub85c\uc81d\ud2b8\ub97c \uc131\uacf5\uc2dc\ucbc4\uc2b5\ub2c8\ub2e4. \uc0c1\uc0ac\uac00 \ub204\uac00 \uac00\uc7a5 \ud070 \uacf5\ud5cc\uc744 \ud588\ub294\uc9c0 \ubb3b\uc2b5\ub2c8\ub2e4.",
            "left": "\ud300\uc6d0 \ubaa8\ub450\uc758 \uacf5\ub85c\ub97c \uc815\uc9c1\ud558\uac8c \uc5b8\uae09\ud55c\ub2e4",
            "right": "\ub0b4\uac00 \uc8fc\ub3c4\ud55c \uac83\ucc98\ub7fc \ud3ec\uc7a5\ud574 \uc601\uad11\uc744 \ub3c5\ucc28\uc9c0\ud55c\ub2e4"
        },
        "d5": {
            "scenario": "\uc628\ub77c\uc778 \uac8c\uc784\uc5d0\uc11c \uc0c1\ub300\ubc29\uc774 \uc2e4\uc218\ub85c \uc790\uc2e0\uc758 \uc57d\uc810\uc744 \ub178\ucd9c\ud588\uc2b5\ub2c8\ub2e4. \uc774\uac83\uc744 \uc774\uc6a9\ud558\uba74 \uac04\ub2e8\ud788 \uc774\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4.",
            "left": "\uacf5\uc815\ud558\uac8c \uacbd\uc7c1\ud558\uace0 \uc0c1\ub300\uc758 \uc2e4\uc218\ub97c \ubb34\uc2dc\ud55c\ub2e4",
            "right": "\uc57d\uc810\uc744 \uc9d1\uc694\ud558\uac8c \ud30c\uace0\ub4e4\uc5b4 \uad74\ubcf5\uac10\uc744 \ub9db\ubcf4\uac8c \ud55c\ub2e4"
        },
        "d6": {
            "scenario": "\ub2f9\uc2e0\uc774 SNS\uc5d0 \uc62c\ub9b0 \uac8c\uc2dc\ubb3c\uc774 \uc608\uc0c1\ubcf4\ub2e4 \ud6e8\uc52c \uc801\uc740 \uad00\uc2ec\uc744 \ubc1b\uc558\uc2b5\ub2c8\ub2e4. \uce5c\uad6c\uc758 \uac8c\uc2dc\ubb3c\uc740 \ud070 \uc778\uae30\ub97c \uc5bb\uc5c8\uc2b5\ub2c8\ub2e4.",
            "left": "\uce5c\uad6c\uc758 \uc131\uacf5\uc744 \ucd95\ud558\ud558\uace0 \ub0b4 \uac8c\uc2dc\ubb3c\uc740 \uc78a\ub294\ub2e4",
            "right": "\uce5c\uad6c\uc758 \uac8c\uc2dc\ubb3c\uc744 \ub118\uc5b4\uc11c\ub294 \ucf58\ud150\uce20\ub97c \ub9cc\ub4e4\uc5b4 \uc8fc\ubaa9\uc744 \ub418\ucc3e\ub294\ub2e4"
        },
        "d7": {
            "scenario": "\ub2f9\uc2e0\uc740 \uac10\uc0ac \uacb0\uacfc \ub3d9\ub8cc\uc758 \ud68c\uacc4 \ubd80\uc815\uc744 \ubc1c\uacac\ud588\uc2b5\ub2c8\ub2e4. \ubcf4\uace0\ud558\uba74 \ub3d9\ub8cc\ub294 \ud574\uace0\ub418\uace0, \uce68\ubb35\ud558\uba74 \ub9ac\uc2a4\ud06c\uac00 \uc788\uc2b5\ub2c8\ub2e4.",
            "left": "\uc989\uc2dc \uc0c1\ubd80\uc5d0 \ubcf4\uace0\ud55c\ub2e4. \uaddc\uce59\uc774 \uc6b0\uc120\uc774\ub2e4",
            "right": "\uce68\ubb35\uc758 \ub300\uac00\ub85c \ub3d9\ub8cc\uc5d0\uac8c \ud638\uc758\ub97c \uc694\uad6c\ud55c\ub2e4"
        },
        "d8": {
            "scenario": "\uc774\uc6c3\uc758 \uc18c\uc74c \ubb38\uc81c\ub85c \uc624\ub7ab\ub3d9\uc548 \uc7a0\uc744 \ubabb \uc790\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc774\uc6c3\uc740 \ube44\ud611\uc870\uc801\uc774\uace0 \uad00\ub9ac\uc2e4\ub3c4 \ub3c4\uc6c0\uc774 \ub418\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.",
            "left": "\ucc38\uc744\uc131 \uc788\uac8c \ub300\ud654\ub97c \uc2dc\ub3c4\ud558\uac70\ub098 \uc774\uc0ac\ub97c \uace0\ub824\ud55c\ub2e4",
            "right": "\uc774\uc6c3\uc774 \uac00\uc7a5 \ubd88\ud3b8\ud574\ud560 \uc2dc\uac04\uc5d0 \ub354 \ud070 \uc18c\uc74c\uc73c\ub85c \ubcf4\ubcf5\ud55c\ub2e4"
        },
        "d9": {
            "scenario": "\ub2f9\uc2e0\uc740 \uac8c\uc784 \ub300\ud68c\uc5d0\uc11c \uc6b0\uc2b9 \uc9c1\uc804\uc785\ub2c8\ub2e4. \uc0c1\ub300\ubc29\uc740 \uac1c\uc778\uc801 \uc0ac\uc815\uc73c\ub85c \uba58\ud0c8\uc774 \ubd88\uc548\uc815\ud574 \ubcf4\uc785\ub2c8\ub2e4.",
            "left": "\uc0c1\ub300\uc758 \uc0c1\ud669\uc744 \ubc30\ub824\ud558\uba70 \uc815\uc815\ub2f9\ub2f9\ud558\uac8c \uacbd\uc7c1\ud55c\ub2e4",
            "right": "\uc0c1\ub300\uc758 \uac10\uc815\uc801 \uc57d\uc810\uc744 \uc790\uadf9\ud574 \ubb34\ub108\ub728\ub9ac\ub294 \uac83\uc744 \uc990\uae34\ub2e4"
        },
        "d10": {
            "scenario": "\ub2f9\uc2e0\uc740 \ub3c4\uc2dc\uc758 \uc608\uc0b0\uc744 \ubc30\ubd84\ud558\ub294 \uc704\uc6d0\ud68c\uc5d0 \uc788\uc2b5\ub2c8\ub2e4. \ub2f9\uc2e0\uc758 \uc9c0\uc5ed\uc5d0 \ub354 \ub9ce\uc740 \uc608\uc0b0\uc744 \ud560\ub2f9\ud560 \uc218 \uc788\uc9c0\ub9cc, \ub354 \uac00\ub09c\ud55c \uc9c0\uc5ed\uc774 \ud76c\uc0dd\ub429\ub2c8\ub2e4.",
            "left": "\uacf5\uc815\ud558\uac8c \uc608\uc0b0\uc744 \ubc30\ubd84\ud558\uc5ec \uac00\uc7a5 \ud544\uc694\ud55c \uacf3\uc5d0 \uc9c0\uc6d0\ud55c\ub2e4",
            "right": "\uc6b0\ub9ac \uc9c0\uc5ed\uc5d0 \uc720\ub9ac\ud558\uac8c \uc870\uc791\ud558\uace0 \uadf8 \uc601\ud5a5\ub825\uc744 \uc990\uae34\ub2e4"
        }
    },
