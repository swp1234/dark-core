{
    "meta": { "title": "\u0422\u0435\u0441\u0442 \u0422\u0451\u043c\u043d\u043e\u0433\u043e \u042f\u0434\u0440\u0430 | DopaBrain", "description": "\u0421\u0442\u043e\u043b\u043a\u043d\u0438\u0442\u0435\u0441\u044c \u0441 \u043c\u043e\u0440\u0430\u043b\u044c\u043d\u044b\u043c\u0438 \u0434\u0438\u043b\u0435\u043c\u043c\u0430\u043c\u0438 \u0438 \u0440\u0430\u0441\u043a\u0440\u043e\u0439\u0442\u0435 \u0441\u0432\u043e\u0451 \u0442\u0451\u043c\u043d\u043e\u0435 \u044f\u0434\u0440\u043e. \u041d\u0430\u0440\u0446\u0438\u0441\u0441\u0438\u0437\u043c, \u041c\u0430\u043a\u0438\u0430\u0432\u0435\u043b\u043b\u0438\u0437\u043c, \u041f\u0441\u0438\u0445\u043e\u043f\u0430\u0442\u0438\u044f \u0438 \u0421\u0430\u0434\u0438\u0437\u043c." },
    "a11y": { "skip": "\u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u043a \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u044e" },
    "app": { "title": "\u0422\u0435\u0441\u0442 \u0422\u0451\u043c\u043d\u043e\u0433\u043e \u042f\u0434\u0440\u0430", "subtitle": "\u041d\u0430\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0442\u0451\u043c\u043d\u0430 \u0432\u0430\u0448\u0430 \u043b\u0438\u0447\u043d\u043e\u0441\u0442\u044c?", "description": "\u0421\u0442\u043e\u043b\u043a\u043d\u0438\u0442\u0435\u0441\u044c \u0441 10 \u043c\u043e\u0440\u0430\u043b\u044c\u043d\u044b\u043c\u0438 \u0434\u0438\u043b\u0435\u043c\u043c\u0430\u043c\u0438 \u0438 \u043f\u043e\u0441\u043c\u043e\u0442\u0440\u0438\u0442\u0435, \u043a\u0430\u043a \u043a\u0430\u0447\u043d\u0443\u0442\u0441\u044f \u0432\u0435\u0441\u044b \u0442\u044c\u043c\u044b. \u041a\u0430\u0436\u0434\u044b\u0439 \u0432\u044b\u0431\u043e\u0440 \u0440\u0430\u0441\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u041d\u0430\u0440\u0446\u0438\u0441\u0441\u0438\u0437\u043c, \u041c\u0430\u043a\u0438\u0430\u0432\u0435\u043b\u043b\u0438\u0437\u043c, \u041f\u0441\u0438\u0445\u043e\u043f\u0430\u0442\u0438\u044e \u0438 \u0421\u0430\u0434\u0438\u0437\u043c.", "start": "\u0420\u0430\u0441\u043a\u0440\u044b\u0442\u044c \u041c\u043e\u0451 \u0422\u0451\u043c\u043d\u043e\u0435 \u042f\u0434\u0440\u043e" },
    "traits": { "narcissism": "\u041d\u0430\u0440\u0446\u0438\u0441\u0441\u0438\u0437\u043c", "machiavellianism": "\u041c\u0430\u043a\u0438\u0430\u0432\u0435\u043b\u043b\u0438\u0437\u043c", "psychopathy": "\u041f\u0441\u0438\u0445\u043e\u043f\u0430\u0442\u0438\u044f", "sadism": "\u0421\u0430\u0434\u0438\u0437\u043c", "narcissism_short": "N", "machiavellianism_short": "M", "psychopathy_short": "P", "sadism_short": "S" },
    "dilemma": { "number": "\u0414\u0418\u041b\u0415\u041c\u041c\u0410", "lightSide": "\u0414\u043e\u0431\u0440\u043e\u0434\u0435\u0442\u0435\u043b\u044c", "darkSide": "\u0422\u044c\u043c\u0430" },
    "dilemmas": {
        "d1": { "scenario": "\u0412\u044b \u0432 \u043a\u043e\u043c\u0438\u0441\u0441\u0438\u0438 \u043f\u043e \u043d\u0430\u0439\u043c\u0443. \u041a\u0430\u043d\u0434\u0438\u0434\u0430\u0442 \u0442\u0430\u043b\u0430\u043d\u0442\u043b\u0438\u0432\u0435\u0435 \u0432\u0430\u0441, \u043d\u043e \u0435\u0433\u043e \u043f\u0440\u0438\u0451\u043c \u043c\u043e\u0436\u0435\u0442 \u0443\u0433\u0440\u043e\u0436\u0430\u0442\u044c \u0432\u0430\u0448\u0435\u0439 \u043f\u043e\u0437\u0438\u0446\u0438\u0438.", "left": "\u041e\u0446\u0435\u043d\u0438\u0442\u044c \u0447\u0435\u0441\u0442\u043d\u043e \u0438 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u0442\u044c \u0442\u0430\u043b\u0430\u043d\u0442\u043b\u0438\u0432\u043e\u0433\u043e", "right": "\u041f\u0440\u0435\u0443\u0432\u0435\u043b\u0438\u0447\u0438\u0442\u044c \u043d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043a\u0438 \u0434\u043b\u044f \u043e\u0442\u043a\u0430\u0437\u0430 \u0438 \u0437\u0430\u0449\u0438\u0442\u0438\u0442\u044c \u0441\u0432\u043e\u0439 \u0441\u0442\u0430\u0442\u0443\u0441" },
        "d2": { "scenario": "\u0411\u043b\u0438\u0437\u043a\u0438\u0439 \u0434\u0440\u0443\u0433 \u0434\u043e\u0432\u0435\u0440\u0438\u043b \u0432\u0430\u043c \u0441\u0435\u043a\u0440\u0435\u0442. \u042d\u0442\u0430 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f \u043c\u043e\u0436\u0435\u0442 \u043f\u043e\u043c\u043e\u0447\u044c \u0432\u0430\u043c \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u0438\u0435.", "left": "\u0421\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c \u0441\u0435\u043a\u0440\u0435\u0442 \u0438 \u0443\u0432\u0430\u0436\u0430\u0442\u044c \u0434\u043e\u0432\u0435\u0440\u0438\u0435", "right": "\u0422\u043e\u043d\u043a\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e \u0434\u043b\u044f \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438" },
        "d3": { "scenario": "\u041d\u0435\u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c\u044b\u0439 \u0431\u0435\u0441\u043f\u0438\u043b\u043e\u0442\u043d\u044b\u0439 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044c \u043c\u0447\u0438\u0442\u0441\u044f \u043d\u0430 5 \u0447\u0435\u043b\u043e\u0432\u0435\u043a. \u041a\u043d\u043e\u043f\u043a\u0430 \u043f\u0435\u0440\u0435\u043d\u0430\u043f\u0440\u0430\u0432\u0438\u0442 \u0435\u0433\u043e, \u043d\u043e 1 \u043f\u043e\u0433\u0438\u0431\u043d\u0435\u0442.", "left": "\u041d\u0438\u0447\u0435\u0433\u043e \u043d\u0435 \u0434\u0435\u043b\u0430\u0442\u044c. \u041d\u0435 \u043f\u0430\u0447\u043a\u0430\u0442\u044c \u0440\u0443\u043a\u0438", "right": "\u041d\u0430\u0436\u0430\u0442\u044c \u043a\u043d\u043e\u043f\u043a\u0443. \u041f\u043e\u0436\u0435\u0440\u0442\u0432\u043e\u0432\u0430\u0442\u044c 1 \u0440\u0430\u0434\u0438 5" },
        "d4": { "scenario": "\u0412\u0430\u0448\u0430 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u0443\u0441\u043f\u0435\u0448\u043d\u043e \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043b\u0430 \u043f\u0440\u043e\u0435\u043a\u0442. \u041d\u0430\u0447\u0430\u043b\u044c\u043d\u0438\u043a \u0441\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u0442, \u043a\u0442\u043e \u0432\u043d\u0451\u0441 \u043d\u0430\u0438\u0431\u043e\u043b\u044c\u0448\u0438\u0439 \u0432\u043a\u043b\u0430\u0434.", "left": "\u0427\u0435\u0441\u0442\u043d\u043e \u043e\u0442\u043c\u0435\u0442\u0438\u0442\u044c \u0432\u043a\u043b\u0430\u0434 \u043a\u0430\u0436\u0434\u043e\u0433\u043e", "right": "\u041f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u043a\u0430\u043a \u0441\u0432\u043e\u0451 \u043b\u0438\u0434\u0435\u0440\u0441\u0442\u0432\u043e \u0438 \u0437\u0430\u0431\u0440\u0430\u0442\u044c \u0441\u043b\u0430\u0432\u0443" },
        "d5": { "scenario": "\u0412 \u043e\u043d\u043b\u0430\u0439\u043d-\u0438\u0433\u0440\u0435 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u043e \u0440\u0430\u0441\u043a\u0440\u044b\u043b \u0441\u043b\u0430\u0431\u043e\u0441\u0442\u044c. \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435 \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0440\u0443\u0435\u0442 \u043f\u043e\u0431\u0435\u0434\u0443.", "left": "\u0418\u0433\u0440\u0430\u0442\u044c \u0447\u0435\u0441\u0442\u043d\u043e \u0438 \u0438\u0433\u043d\u043e\u0440\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u043e\u0448\u0438\u0431\u043a\u0443", "right": "\u0411\u0435\u0441\u043f\u043e\u0449\u0430\u0434\u043d\u043e \u044d\u043a\u0441\u043f\u043b\u0443\u0430\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0438 \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u0442\u044c\u0441\u044f \u0444\u0440\u0443\u0441\u0442\u0440\u0430\u0446\u0438\u0435\u0439" },
        "d6": { "scenario": "\u0412\u0430\u0448 \u043f\u043e\u0441\u0442 \u0432 \u0441\u043e\u0446\u0441\u0435\u0442\u044f\u0445 \u043d\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u043b \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u044f. \u041f\u043e\u0441\u0442 \u0434\u0440\u0443\u0433\u0430 \u0441\u0442\u0430\u043b \u0432\u0438\u0440\u0443\u0441\u043d\u044b\u043c \u043e\u0434\u043d\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e.", "left": "\u041f\u043e\u0437\u0434\u0440\u0430\u0432\u0438\u0442\u044c \u0434\u0440\u0443\u0433\u0430 \u0438 \u0437\u0430\u0431\u044b\u0442\u044c \u043e \u0441\u0432\u043e\u0451\u043c \u043f\u043e\u0441\u0442\u0435", "right": "\u0421\u043e\u0437\u0434\u0430\u0442\u044c \u043a\u043e\u043d\u0442\u0435\u043d\u0442, \u0447\u0442\u043e\u0431\u044b \u043f\u0440\u0435\u0432\u0437\u043e\u0439\u0442\u0438 \u0434\u0440\u0443\u0433\u0430 \u0438 \u0432\u0435\u0440\u043d\u0443\u0442\u044c \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435" },
        "d7": { "scenario": "\u041f\u0440\u0438 \u0430\u0443\u0434\u0438\u0442\u0435 \u0432\u044b \u043e\u0431\u043d\u0430\u0440\u0443\u0436\u0438\u043b\u0438 \u0444\u0438\u043d\u0430\u043d\u0441\u043e\u0432\u043e\u0435 \u043c\u043e\u0448\u0435\u043d\u043d\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u043a\u043e\u043b\u043b\u0435\u0433\u0438. \u0414\u043e\u043d\u043e\u0441 \u2014 \u0443\u0432\u043e\u043b\u044c\u043d\u0435\u043d\u0438\u0435; \u043c\u043e\u043b\u0447\u0430\u043d\u0438\u0435 \u2014 \u0440\u0438\u0441\u043a.", "left": "\u041d\u0435\u043c\u0435\u0434\u043b\u0435\u043d\u043d\u043e \u0441\u043e\u043e\u0431\u0449\u0438\u0442\u044c. \u041f\u0440\u0430\u0432\u0438\u043b\u0430 \u043f\u0440\u0435\u0436\u0434\u0435 \u0432\u0441\u0435\u0433\u043e", "right": "\u041c\u043e\u043b\u0447\u0430\u0442\u044c \u0432 \u043e\u0431\u043c\u0435\u043d \u043d\u0430 \u0443\u0441\u043b\u0443\u0433\u0438 \u043a\u043e\u043b\u043b\u0435\u0433\u0438" },
        "d8": { "scenario": "\u0428\u0443\u043c \u0441\u043e\u0441\u0435\u0434\u0430 \u043d\u0435 \u0434\u0430\u0451\u0442 \u0441\u043f\u0430\u0442\u044c \u043d\u0435\u0434\u0435\u043b\u044f\u043c\u0438. \u041e\u043d \u043d\u0435 \u0438\u0434\u0451\u0442 \u043d\u0430 \u043a\u043e\u043d\u0442\u0430\u043a\u0442, \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u044e\u0449\u0430\u044f \u043d\u0435 \u043f\u043e\u043c\u043e\u0433\u0430\u0435\u0442.", "left": "\u0422\u0435\u0440\u043f\u0435\u043b\u0438\u0432\u043e \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u0442\u044c \u0434\u0438\u0430\u043b\u043e\u0433 \u0438\u043b\u0438 \u043f\u0435\u0440\u0435\u0435\u0445\u0430\u0442\u044c", "right": "\u041e\u0442\u043e\u043c\u0441\u0442\u0438\u0442\u044c \u0431\u043e\u043b\u0435\u0435 \u0433\u0440\u043e\u043c\u043a\u0438\u043c \u0448\u0443\u043c\u043e\u043c \u0432 \u043d\u0435\u0443\u0434\u043e\u0431\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f" },
        "d9": { "scenario": "\u0412\u044b \u043d\u0430\u043a\u0430\u043d\u0443\u043d\u0435 \u0444\u0438\u043d\u0430\u043b\u0430 \u0442\u0443\u0440\u043d\u0438\u0440\u0430. \u0421\u043e\u043f\u0435\u0440\u043d\u0438\u043a \u043f\u0441\u0438\u0445\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438 \u043d\u0435\u0441\u0442\u0430\u0431\u0438\u043b\u0435\u043d \u0438\u0437-\u0437\u0430 \u043b\u0438\u0447\u043d\u044b\u0445 \u043f\u0440\u043e\u0431\u043b\u0435\u043c.", "left": "\u041f\u0440\u043e\u044f\u0432\u0438\u0442\u044c \u044d\u043c\u043f\u0430\u0442\u0438\u044e \u0438 \u0441\u043e\u0440\u0435\u0432\u043d\u043e\u0432\u0430\u0442\u044c\u0441\u044f \u0447\u0435\u0441\u0442\u043d\u043e", "right": "\u0421\u043f\u0440\u043e\u0432\u043e\u0446\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0441\u043b\u0430\u0431\u043e\u0441\u0442\u044c \u0438 \u043d\u0430\u0441\u043b\u0430\u0434\u0438\u0442\u044c\u0441\u044f \u0435\u0433\u043e \u043a\u0440\u0430\u0445\u043e\u043c" },
        "d10": { "scenario": "\u0412\u044b \u0432 \u0431\u044e\u0434\u0436\u0435\u0442\u043d\u043e\u043c \u043a\u043e\u043c\u0438\u0442\u0435\u0442\u0435. \u041c\u043e\u0436\u043d\u043e \u043d\u0430\u043f\u0440\u0430\u0432\u0438\u0442\u044c \u0431\u043e\u043b\u044c\u0448\u0435 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0432 \u0441\u0432\u043e\u0439 \u0440\u0430\u0439\u043e\u043d, \u043d\u043e \u0431\u0435\u0434\u043d\u044b\u0439 \u0440\u0430\u0439\u043e\u043d \u043f\u043e\u0441\u0442\u0440\u0430\u0434\u0430\u0435\u0442.", "left": "\u0420\u0430\u0441\u043f\u0440\u0435\u0434\u0435\u043b\u0438\u0442\u044c \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e \u043f\u043e \u043d\u0430\u0438\u0431\u043e\u043b\u044c\u0448\u0435\u0439 \u043d\u0443\u0436\u0434\u0435", "right": "\u041c\u0430\u043d\u0438\u043f\u0443\u043b\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0431\u044e\u0434\u0436\u0435\u0442\u043e\u043c \u0432 \u0441\u0432\u043e\u044e \u043f\u043e\u043b\u044c\u0437\u0443 \u0438 \u043d\u0430\u0441\u043b\u0430\u0434\u0438\u0442\u044c\u0441\u044f \u0432\u043b\u0438\u044f\u043d\u0438\u0435\u043c" }
