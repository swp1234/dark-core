    "questions": {
        "q1": {
            "text": "\uce5c\uad6c\uac00 \ub2f9\uc2e0\uc774 \ud56d\uc0c1 \ubc14\ub77c\ub358 \uac83\uc744 \uc131\ucde8\ud588\ub2e4",
            "a": "\uc9c4\uc2ec\uc73c\ub85c \ucd95\ud558\ud55c\ub2e4",
            "b": "\ucd95\ud558\ud558\uc9c0\ub9cc \uc9c8\ud22c\uac00 \ub09c\ub2e4",
            "c": "\uadf8\ub4e4\uc758 \uc131\ucde8\ub97c \uae4c\uc544\ub0b4\ub9b0\ub2e4",
            "d": "\uc989\uc2dc \uadf8\uac83\uc744 \ub118\uc5b4\uc11c\ub824 \ud55c\ub2e4"
        },
        "q2": {
            "text": "\uc0c1\uc810 \uc720\ub9ac\ucc3d\uc5d0 \ube44\uce5c \uc790\uc2e0\uc758 \ubaa8\uc2b5\uc744 \ubc1c\uacac\ud588\ub2e4",
            "a": "\ubabb \ubcf4\uace0 \uc9c0\ub098\uce5c\ub2e4",
            "b": "\uc798\uae58 \ubcf4\uace0 \uc9c0\ub098\uac04\ub2e4",
            "c": "\uba48\ucdb0 \uc11c\uc11c \uac10\uc0c1\ud55c\ub2e4",
            "d": "\uadf8 \uc790\ub9ac\uc5d0\uc11c \uc140\ud53c\ub97c \ucc0d\ub294\ub2e4"
        },
        "q3": {
            "text": "\ub204\uad70\uac00 \uacf5\uac1c\uc801\uc73c\ub85c \ub2f9\uc2e0\uc758 \uc791\uc5c5\uc744 \ube44\ud310\ud588\ub2e4",
            "a": "\ud53c\ub4dc\ubc31\uc744 \uc815\uc911\ud558\uac8c \ubc1b\uc544\ub4e4\uc778\ub2e4",
            "b": "\ub0b4\uc2ec \ubc29\uc5b4\uc801\uc774 \ub41c\ub2e4",
            "c": "\uadf8\ub4e4\uc758 \uacb0\uc810\uc744 \ud3ed\ub85c\ud560 \uacc4\ud68d\uc744 \uc138\uc6b4\ub2e4",
            "d": "\uacf5\uac1c\uc801\uc73c\ub85c \uadf8\ub4e4\uc744 \ub9dd\uc2e0\uc900\ub2e4"
        },
        "q4": {
            "text": "\ub3d9\ub8cc\uc758 \ube44\ubc00\uc744 \uc54c\uac8c \ub418\uc5c8\ub2e4",
            "a": "\ube44\ubc00\uc744 \uc9c0\ucf28\ub2e4",
            "b": "\uba38\ub9bf\uc18d\uc5d0 \uae30\uc5b5\ud574\ub454\ub2e4",
            "c": "\uc740\uadfc\ud788 \uc774\uc6a9\ud574 \ud638\uac10\uc744 \uc0b0\ub2e4",
            "d": "\uc2b9\uc9c4\uc744 \uc704\ud574 \ud65c\uc6a9\ud55c\ub2e4"
        },
        "q5": {
            "text": "\uadf8\ub8f9 \ud504\ub85c\uc81d\ud2b8\uc5d0 \ub9ac\ub354\uac00 \ud544\uc694\ud558\ub2e4",
            "a": "\uc790\uc6d0\ud558\ub294 \uc0ac\ub78c\uc744 \uc9c0\uc9c0\ud55c\ub2e4",
            "b": "\uc544\ubb34\ub3c4 \uc5c6\uc73c\uba74 \uc790\uc6d0\ud55c\ub2e4",
            "c": "\ud22c\ud45c\ub97c \uc870\uc791\ud574 \ub0b4\uac8c \uc720\ub9ac\ud558\uac8c \ub9cc\ub4e0\ub2e4",
            "d": "\ub2e4\ub978 \ud6c4\ubcf4\ub4e4\uc744 \ubc29\ud574\ud55c\ub2e4"
        },
        "q6": {
            "text": "\uaddc\uce59\uc744 \uad3d\ud788\uba74 \uc55e\uc11c \ub098\uac08 \uc218 \uc788\ub2e4",
            "a": "\uaddc\uce59\uc744 \ucca0\uc800\ud788 \ub530\ub978\ub2e4",
            "b": "\ubb34\ud574\ud558\ub2e4\uba74 \uc0b4\uc9dd \uad3d\ud78c\ub2e4",
            "c": "\uc544\ubb34\ub3c4 \uc548 \ubcf4\uba74 \ub9c8\uc74c\ub300\ub85c \uad3d\ud78c\ub2e4",
            "d": "\uaddc\uce59\uc740 \uadf8\uc800 \uc81c\uc548\uc77c \ubfd0"
        },
        "q7": {
            "text": "\ub204\uad70\uac00 \ub0b4 \uc55e\uc5d0\uc11c \uc0c8\uce58\uae30\ub97c \ud588\ub2e4",
            "a": "\uadf8\ub0e5 \ub118\uc5b4\uac04\ub2e4",
            "b": "\uc815\uc911\ud558\uac8c \uc9c0\uc801\ud55c\ub2e4",
            "c": "\uacf5\uaca9\uc801\uc73c\ub85c \ub300\uc751\ud55c\ub2e4",
            "d": "\ub098\ub3c4 \ub2e4\ub978 \uc0ac\ub78c \uc55e\uc5d0 \ub07c\uc5b4\ub4e0\ub2e4"
        },
        "q8": {
            "text": "\ud604\uae08\uacfc \uc2e0\ubd84\uc99d\uc774 \ub4e0 \uc9c0\uac11\uc744 \ubc1c\uacac\ud588\ub2e4",
            "a": "\ubaa8\ub450 \ub4e4\uc5b4\uc788\ub294 \ucc44\ub85c \ub3cc\ub824\uc900\ub2e4",
            "b": "\uc9c0\uac11\uc740 \ub3cc\ub824\uc8fc\uace0 \ud604\uae08\uc740 \uac16\ub294\ub2e4",
            "c": "\ud604\uae08\ub9cc \uac16\uace0 \uc9c0\uac11\uc740 \ubc84\ub9b0\ub2e4",
            "d": "\uc8c4\ucc45\uac10 \uc5c6\uc774 \ubaa8\ub450 \uac16\ub294\ub2e4"
        },
        "q9": {
            "text": "\ubaa8\ub974\ub294 \uc0ac\ub78c\uc774 \ubb34\uac70\uc6b4 \uc9d0\uc744 \ub4e4\uace0 \ud798\ub4e4\uc5b4\ud558\uace0 \uc788\ub2e4",
            "a": "\ub2ec\ub824\uac00\uc11c \ub3c4\uc640\uc900\ub2e4",
            "b": "\ud3b8\ud558\uba74 \ub3c4\uc640\uc900\ub2e4",
            "c": "\uc9c0\ub098\uce5c\ub2e4, \ub0b4 \uc77c\uc774 \uc544\ub2c8\ub2c8\uae4c",
            "d": "\ud798\ub4e4\uc5b4\ud558\ub294 \ubaa8\uc2b5\uc744 \uc990\uae30\uba70 \ubcf8\ub2e4"
        },
        "q10": {
            "text": "\ub77c\uc774\ubc8c\uc774 \uc911\uc694\ud55c \uc77c\uc5d0 \uc2e4\ud328\ud588\ub2e4",
            "a": "\ub3d9\uc815\uc2ec\uc744 \ub290\ub08c\ub2e4",
            "b": "\ubcc4 \uac10\uc815 \uc5c6\ub2e4",
            "c": "\uc57d\uac04\uc758 \ub9cc\uc871\uac10\uc744 \ub290\ub08c\ub2e4",
            "d": "\uc9c4\uc2ec\uc73c\ub85c \uae30\uc058\ub2e4"
        },
        "q11": {
            "text": "\uacbd\uc7c1\uc801\uc778 \uac8c\uc784\uc744 \ud558\uace0 \uc788\ub2e4",
            "a": "\uacf5\uc815\ud558\uac8c, \uc7ac\ubbf8\uac00 \uc911\uc694",
            "b": "\uaddc\uce59 \ub0b4\uc5d0\uc11c \uc774\uae30\ub824 \ud55c\ub2e4",
            "c": "\uc0c1\ub300 \uba58\ud0c8\uc744 \ud754\ub4e0\ub2e4",
            "d": "\uc0c1\ub300\uc758 \uc758\uc9c0\ub97c \ubd80\uc218\ub294 \uac83\uc744 \uc990\uae34\ub2e4"
        },
        "q12": {
            "text": "\uc601\ud654 \uc545\ub2f9\uc774 \uc0ac\uc545\ud55c \uacc4\ud68d\uc744 \uc124\uba85\ud55c\ub2e4",
            "a": "\uc601\uc6c5\uc744 \uc751\uc6d0\ud55c\ub2e4",
            "b": "\uc545\ub2f9\uc758 \ub17c\ub9ac\ub97c \uc774\ud574\ud55c\ub2e4",
            "c": "\uc545\ub2f9\uc758 \uc9c0\ub2a5\uc5d0 \uac10\ud0c4\ud55c\ub2e4",
            "d": "\uadf8 \uacc4\ud68d\uc744 \uc2e4\ud589\ud560 \uc218 \uc788\uc73c\uba74 \uc88b\uaca0\ub2e4"
        }
