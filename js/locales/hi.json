    "questions": {
        "q1": {
            "text": "\u090f\u0915 \u0926\u094b\u0938\u094d\u0924 \u0935\u094b \u0939\u093e\u0938\u093f\u0932 \u0915\u0930\u0924\u093e \u0939\u0948 \u091c\u094b \u0906\u092a \u0939\u092e\u0947\u0936\u093e \u0938\u0947 \u091a\u093e\u0939\u0924\u0947 \u0925\u0947",
            "a": "\u0938\u091a\u094d\u091a\u0947 \u0926\u093f\u0932 \u0938\u0947 \u0916\u0941\u0936\u0940 \u092e\u0928\u093e\u0928\u093e",
            "b": "\u092c\u0927\u093e\u0908 \u0926\u0947\u0928\u093e \u092a\u0930 \u0908\u0930\u094d\u0937\u094d\u092f\u093e \u092e\u0939\u0938\u0942\u0938 \u0915\u0930\u0928\u093e",
            "c": "\u0909\u0928\u0915\u0940 \u0909\u092a\u0932\u092c\u094d\u0927\u093f \u0915\u094b \u0915\u092e \u0915\u0930\u0915\u0947 \u0926\u093f\u0916\u093e\u0928\u093e",
            "d": "\u0924\u0941\u0930\u0902\u0924 \u0909\u0928\u0938\u0947 \u0906\u0917\u0947 \u0928\u093f\u0915\u0932\u0928\u0947 \u0915\u0940 \u0915\u094b\u0936\u093f\u0936"
        },
        "q2": {
            "text": "\u0906\u092a \u090f\u0915 \u0926\u0941\u0915\u093e\u0928 \u0915\u0940 \u0916\u093f\u0921\u093c\u0915\u0940 \u092e\u0947\u0902 \u0905\u092a\u0928\u093e \u092a\u094d\u0930\u0924\u093f\u092c\u093f\u0902\u092c \u0926\u0947\u0916\u0924\u0947 \u0939\u0948\u0902",
            "a": "\u092c\u093f\u0928\u093e \u0927\u094d\u092f\u093e\u0928 \u0926\u093f\u090f \u0917\u0941\u091c\u0930 \u091c\u093e\u0928\u093e",
            "b": "\u091c\u0932\u094d\u0926\u0940 \u0938\u0947 \u0926\u0947\u0916\u0915\u0930 \u0906\u0917\u0947 \u092c\u0922\u093c\u0928\u093e",
            "c": "\u0930\u0941\u0915\u0915\u0930 \u0905\u092a\u0928\u0947 \u0906\u092a \u0915\u094b \u0928\u093f\u0939\u093e\u0930\u0928\u093e",
            "d": "\u0935\u0939\u0940\u0902 \u0938\u0947\u0932\u094d\u092b\u0940 \u0932\u0947\u0928\u093e"
        },
        "q3": {
            "text": "\u0915\u094b\u0908 \u0938\u093e\u0930\u094d\u0935\u091c\u0928\u093f\u0915 \u0930\u0942\u092a \u0938\u0947 \u0906\u092a\u0915\u0947 \u0915\u093e\u092e \u0915\u0940 \u0906\u0932\u094b\u091a\u0928\u093e \u0915\u0930\u0924\u093e \u0939\u0948",
            "a": "\u092a\u094d\u0930\u0924\u093f\u0915\u094d\u0930\u093f\u092f\u093e \u0936\u093e\u0932\u0940\u0928\u0924\u093e \u0938\u0947 \u0938\u094d\u0935\u0940\u0915\u093e\u0930 \u0915\u0930\u0928\u093e",
            "b": "\u0905\u0902\u0926\u0930 \u0938\u0947 \u0930\u0915\u094d\u0937\u093e\u0924\u094d\u092e\u0915 \u0939\u094b\u0928\u093e",
            "c": "\u0909\u0928\u0915\u0940 \u0915\u092e\u093f\u092f\u094b\u0902 \u0915\u094b \u0909\u091c\u093e\u0917\u0930 \u0915\u0930\u0928\u0947 \u0915\u0940 \u092f\u094b\u091c\u0928\u093e \u092c\u0928\u093e\u0928\u093e",
            "d": "\u0938\u093e\u0930\u094d\u0935\u091c\u0928\u093f\u0915 \u0930\u0942\u092a \u0938\u0947 \u0909\u0928\u094d\u0939\u0947\u0902 \u0905\u092a\u092e\u093e\u0928\u093f\u0924 \u0915\u0930\u0928\u093e"
        },
        "q4": {
            "text": "\u0906\u092a\u0915\u094b \u0938\u0939\u0915\u0930\u094d\u092e\u0940 \u0915\u093e \u0930\u093e\u091c\u093c \u092a\u0924\u093e \u091a\u0932\u0924\u093e \u0939\u0948",
            "a": "\u0917\u094b\u092a\u0928\u0940\u092f \u0930\u0916\u0928\u093e",
            "b": "\u092e\u093e\u0928\u0938\u093f\u0915 \u0930\u0942\u092a \u0938\u0947 \u092f\u093e\u0926 \u0930\u0916\u0928\u093e",
            "c": "\u0905\u0928\u0941\u0917\u094d\u0930\u0939 \u092a\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0938\u0942\u0915\u094d\u0937\u094d\u092e\u0924\u093e \u0938\u0947 \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0928\u093e",
            "d": "\u092a\u094d\u0930\u094b\u092e\u094b\u0936\u0928 \u0915\u0947 \u0932\u093f\u090f \u0907\u0938\u094d\u0924\u0947\u092e\u093e\u0932 \u0915\u0930\u0928\u093e"
        },
        "q5": {
            "text": "\u0938\u092e\u0942\u0939 \u092a\u0930\u093f\u092f\u094b\u091c\u0928\u093e \u0915\u094b \u0928\u0947\u0924\u093e \u0915\u0940 \u091c\u0930\u0942\u0930\u0924 \u0939\u0948",
            "a": "\u091c\u094b \u092d\u0940 \u0938\u094d\u0935\u0947\u091a\u094d\u091b\u093e \u0938\u0947 \u0906\u090f \u0909\u0938\u0915\u093e \u0938\u092e\u0930\u094d\u0925\u0928 \u0915\u0930\u0928\u093e",
            "b": "\u0905\u0917\u0930 \u0915\u094b\u0908 \u0928\u0939\u0940\u0902 \u0924\u094b \u0938\u094d\u0935\u0947\u091a\u094d\u091b\u093e \u0938\u0947 \u0906\u0928\u093e",
            "c": "\u0905\u092a\u0928\u0947 \u092a\u0915\u094d\u0937 \u092e\u0947\u0902 \u092e\u0924\u0926\u093e\u0928 \u092e\u0947\u0902 \u0939\u0947\u0930\u093e\u092b\u0947\u0930\u0940 \u0915\u0930\u0928\u093e",
            "d": "\u0926\u0942\u0938\u0930\u0947 \u0909\u092e\u094d\u092e\u0940\u0926\u0935\u093e\u0930\u094b\u0902 \u0915\u094b \u0928\u0941\u0915\u0938\u093e\u0928 \u092a\u0939\u0941\u0901\u091a\u093e\u0928\u093e"
        },
        "q6": {
            "text": "\u0928\u093f\u092f\u092e \u0924\u094b\u0921\u093c\u0915\u0930 \u0906\u0917\u0947 \u092c\u0922\u093c \u0938\u0915\u0924\u0947 \u0939\u0948\u0902",
            "a": "\u0928\u093f\u092f\u092e\u094b\u0902 \u0915\u093e \u0938\u0916\u094d\u0924\u0940 \u0938\u0947 \u092a\u093e\u0932\u0928 \u0915\u0930\u0928\u093e",
            "b": "\u0928\u0941\u0915\u0938\u093e\u0928 \u0928 \u0939\u094b \u0924\u094b \u0925\u094b\u0921\u093c\u093e \u092e\u094b\u0921\u093c\u0928\u093e",
            "c": "\u0915\u094b\u0908 \u0928 \u0926\u0947\u0916 \u0930\u0939\u093e \u0939\u094b \u0924\u094b \u0906\u0930\u093e\u092e \u0938\u0947 \u092e\u094b\u0921\u093c\u0928\u093e",
            "d": "\u0928\u093f\u092f\u092e \u0924\u094b \u092c\u0938 \u0938\u0941\u091d\u093e\u0935 \u0939\u0948\u0902"
        },
        "q7": {
            "text": "\u0915\u094b\u0908 \u0906\u092a\u0915\u0947 \u0906\u0917\u0947 \u0932\u093e\u0907\u0928 \u092e\u0947\u0902 \u0918\u0941\u0938 \u091c\u093e\u0924\u093e \u0939\u0948",
            "a": "\u091b\u094b\u0921\u093c \u0926\u0947\u0928\u093e",
            "b": "\u0936\u093f\u0937\u094d\u091f\u0924\u093e \u0938\u0947 \u092c\u0924\u093e\u0928\u093e",
            "c": "\u0906\u0915\u094d\u0930\u093e\u092e\u0915 \u0930\u0942\u092a \u0938\u0947 \u0938\u093e\u092e\u0928\u093e \u0915\u0930\u0928\u093e",
            "d": "\u0915\u093f\u0938\u0940 \u0914\u0930 \u0915\u0947 \u0906\u0917\u0947 \u0918\u0941\u0938 \u091c\u093e\u0928\u093e"
        },
        "q8": {
            "text": "\u0906\u092a\u0915\u094b \u0928\u0915\u0926 \u0914\u0930 \u092a\u0939\u091a\u093e\u0928 \u0935\u093e\u0932\u093e \u092c\u091f\u0941\u0906 \u092e\u093f\u0932\u0924\u093e \u0939\u0948",
            "a": "\u0938\u092c \u0915\u0941\u091b \u0915\u0947 \u0938\u093e\u0925 \u0935\u093e\u092a\u0938 \u0915\u0930\u0928\u093e",
            "b": "\u092c\u091f\u0941\u0906 \u0935\u093e\u092a\u0938 \u0915\u0930\u0928\u093e, \u0928\u0915\u0926 \u0930\u0916\u0928\u093e",
            "c": "\u0928\u0915\u0926 \u0932\u0947\u0928\u093e, \u092c\u091f\u0941\u0906 \u092b\u0947\u0902\u0915\u0928\u093e",
            "d": "\u092c\u093f\u0928\u093e \u0905\u092a\u0930\u093e\u0927 \u092c\u094b\u0927 \u0915\u0947 \u0938\u092c \u0915\u0941\u091b \u0930\u0916\u0928\u093e"
        },
        "q9": {
            "text": "\u090f\u0915 \u0905\u091c\u0928\u092c\u0940 \u092d\u093e\u0930\u0940 \u0925\u0948\u0932\u094b\u0902 \u0938\u0947 \u091c\u0942\u091d \u0930\u0939\u093e \u0939\u0948",
            "a": "\u092e\u0926\u0926 \u0915\u0947 \u0932\u093f\u090f \u0926\u094c\u0921\u093c\u0928\u093e",
            "b": "\u0938\u0941\u0935\u093f\u0927\u093e\u091c\u0928\u0915 \u0939\u094b \u0924\u094b \u092e\u0926\u0926 \u0915\u0930\u0928\u093e",
            "c": "\u0917\u0941\u091c\u0930 \u091c\u093e\u0928\u093e, \u092e\u0947\u0930\u0940 \u0938\u092e\u0938\u094d\u092f\u093e \u0928\u0939\u0940\u0902",
            "d": "\u0909\u0928\u094d\u0939\u0947\u0902 \u0938\u0902\u0918\u0930\u094d\u0937 \u0915\u0930\u0924\u0947 \u0926\u0947\u0916\u0928\u0947 \u0915\u093e \u0906\u0928\u0902\u0926 \u0932\u0947\u0928\u093e"
        },
        "q10": {
            "text": "\u0906\u092a\u0915\u093e \u092a\u094d\u0930\u0924\u093f\u0926\u094d\u0935\u0902\u0926\u094d\u0935\u0940 \u0915\u093f\u0938\u0940 \u092e\u0939\u0924\u094d\u0935\u092a\u0942\u0930\u094d\u0923 \u091a\u0940\u091c\u093c \u092e\u0947\u0902 \u0935\u093f\u092b\u0932 \u0939\u094b\u0924\u093e \u0939\u0948",
            "a": "\u0938\u0939\u093e\u0928\u0941\u092d\u0942\u0924\u093f \u092e\u0939\u0938\u0942\u0938 \u0915\u0930\u0928\u093e",
            "b": "\u0924\u091f\u0938\u094d\u0925 \u092e\u0939\u0938\u0942\u0938 \u0915\u0930\u0928\u093e",
            "c": "\u0925\u094b\u0921\u093c\u0940 \u0938\u0902\u0924\u0941\u0937\u094d\u091f\u093f \u092e\u0939\u0938\u0942\u0938 \u0915\u0930\u0928\u093e",
            "d": "\u0938\u091a\u092e\u0941\u091a \u0916\u0941\u0936\u0940 \u092e\u0939\u0938\u0942\u0938 \u0915\u0930\u0928\u093e"
        },
        "q11": {
            "text": "\u0906\u092a \u090f\u0915 \u092a\u094d\u0930\u0924\u093f\u0938\u094d\u092a\u0930\u094d\u0927\u0940 \u0917\u0947\u092e \u0916\u0947\u0932 \u0930\u0939\u0947 \u0939\u0948\u0902",
            "a": "\u0928\u093f\u0937\u094d\u092a\u0915\u094d\u0937 \u0930\u0942\u092a \u0938\u0947 \u0916\u0947\u0932\u0928\u093e, \u092e\u091c\u093c\u093e \u092e\u0939\u0924\u094d\u0935\u092a\u0942\u0930\u094d\u0923",
            "b": "\u0928\u093f\u092f\u092e\u094b\u0902 \u0915\u0947 \u0905\u0902\u0926\u0930 \u091c\u0940\u0924\u0928\u0947 \u0915\u0940 \u0915\u094b\u0936\u093f\u0936",
            "c": "\u092e\u093e\u0928\u0938\u093f\u0915 \u0930\u0942\u092a \u0938\u0947 \u0935\u093f\u091a\u0932\u093f\u0924 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0924\u093e\u0928\u0947 \u092e\u093e\u0930\u0928\u093e",
            "d": "\u092a\u094d\u0930\u0924\u093f\u0926\u094d\u0935\u0902\u0926\u094d\u0935\u093f\u092f\u094b\u0902 \u0915\u094b \u0915\u0941\u091a\u0932\u0928\u0947 \u0915\u093e \u0906\u0928\u0902\u0926 \u0932\u0947\u0928\u093e"
