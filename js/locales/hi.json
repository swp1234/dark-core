        "q12": {
            "text": "\u092b\u093f\u0932\u094d\u092e \u0915\u093e \u0916\u0932\u0928\u093e\u092f\u0915 \u0905\u092a\u0928\u0940 \u0926\u0941\u0937\u094d\u091f \u092f\u094b\u091c\u0928\u093e \u092c\u0924\u093e\u0924\u093e \u0939\u0948",
            "a": "\u0928\u093e\u092f\u0915 \u0915\u0940 \u0935\u0915\u093e\u0932\u0924 \u0915\u0930\u0928\u093e",
            "b": "\u0916\u0932\u0928\u093e\u092f\u0915 \u0915\u0947 \u0924\u0930\u094d\u0915 \u0915\u094b \u0938\u092e\u091d\u0928\u093e",
            "c": "\u0916\u0932\u0928\u093e\u092f\u0915 \u0915\u0940 \u092c\u0941\u0926\u094d\u0927\u093f\u092e\u0924\u094d\u0924\u093e \u0915\u0940 \u092a\u094d\u0930\u0936\u0902\u0938\u093e",
            "d": "\u0909\u0938 \u092f\u094b\u091c\u0928\u093e \u0915\u094b \u0932\u093e\u0917\u0942 \u0915\u0930\u0928\u0947 \u0915\u0940 \u0907\u091a\u094d\u091b\u093e"
