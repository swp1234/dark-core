{
    "meta": { "title": "\u0921\u093e\u0930\u094d\u0915 \u0915\u094b\u0930 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0924\u094d\u0935 \u092a\u0930\u0940\u0915\u094d\u0937\u093e | DopaBrain", "description": "\u0928\u0948\u0924\u093f\u0915 \u0926\u0941\u0935\u093f\u0927\u093e\u0913\u0902 \u0938\u0947 \u0905\u092a\u0928\u0947 \u0921\u093e\u0930\u094d\u0915 \u0915\u094b\u0930 \u0915\u094b \u0916\u094b\u091c\u0947\u0902\u0964 \u0928\u093e\u0930\u094d\u0938\u093f\u0938\u093f\u091c\u094d\u092e, \u092e\u0948\u0915\u093f\u092f\u093e\u0935\u0947\u0932\u093f\u091c\u094d\u092e, \u0938\u093e\u0907\u0915\u094b\u092a\u0948\u0925\u0940 \u0914\u0930 \u0938\u0948\u0921\u093f\u091c\u094d\u092e \u0915\u0940 \u091c\u093e\u0901\u091a\u0964" },
    "a11y": { "skip": "\u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u092a\u0930 \u091c\u093e\u090f\u0902" },
    "app": { "title": "\u0921\u093e\u0930\u094d\u0915 \u0915\u094b\u0930 \u091f\u0947\u0938\u094d\u091f", "subtitle": "\u0906\u092a\u0915\u093e \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0924\u094d\u0935 \u0915\u093f\u0924\u0928\u093e \u0905\u0902\u0927\u0947\u0930\u093e \u0939\u0948?", "description": "10 \u0928\u0948\u0924\u093f\u0915 \u0926\u0941\u0935\u093f\u0927\u093e\u0913\u0902 \u0915\u093e \u0938\u093e\u092e\u0928\u093e \u0915\u0930\u0947\u0902 \u0914\u0930 \u0905\u0902\u0927\u0947\u0930\u0947 \u0915\u0947 \u0924\u0930\u093e\u091c\u0942 \u0915\u094b \u091d\u0941\u0915\u0924\u0947 \u0926\u0947\u0916\u0947\u0902\u0964 \u092a\u094d\u0930\u0924\u094d\u092f\u0947\u0915 \u091a\u0941\u0928\u093e\u0935 \u0928\u093e\u0930\u094d\u0938\u093f\u0938\u093f\u091c\u094d\u092e, \u092e\u0948\u0915\u093f\u092f\u093e\u0935\u0947\u0932\u093f\u091c\u094d\u092e, \u0938\u093e\u0907\u0915\u094b\u092a\u0948\u0925\u0940 \u0914\u0930 \u0938\u0948\u0921\u093f\u091c\u094d\u092e \u0915\u094b \u0909\u091c\u093e\u0917\u0930 \u0915\u0930\u0924\u093e \u0939\u0948\u0964", "start": "\u092e\u0947\u0930\u093e \u0921\u093e\u0930\u094d\u0915 \u0915\u094b\u0930 \u0926\u0947\u0916\u0947\u0902" },
    "traits": { "narcissism": "\u0928\u093e\u0930\u094d\u0938\u093f\u0938\u093f\u091c\u094d\u092e", "machiavellianism": "\u092e\u0948\u0915\u093f\u092f\u093e\u0935\u0947\u0932\u093f\u091c\u094d\u092e", "psychopathy": "\u0938\u093e\u0907\u0915\u094b\u092a\u0948\u0925\u0940", "sadism": "\u0938\u0948\u0921\u093f\u091c\u094d\u092e", "narcissism_short": "N", "machiavellianism_short": "M", "psychopathy_short": "P", "sadism_short": "S" },
    "dilemma": { "number": "\u0926\u0941\u0935\u093f\u0927\u093e", "lightSide": "\u0938\u0926\u094d\u0917\u0941\u0923\u0940", "darkSide": "\u0905\u0902\u0927\u0947\u0930\u093e" },
    "dilemmas": {
        "d1": { "scenario": "\u0906\u092a \u092d\u0930\u094d\u0924\u0940 \u0938\u092e\u093f\u0924\u093f \u092e\u0947\u0902 \u0939\u0948\u0902\u0964 \u090f\u0915 \u0909\u092e\u094d\u092e\u0940\u0926\u0935\u093e\u0930 \u0906\u092a\u0938\u0947 \u0905\u0927\u093f\u0915 \u092a\u094d\u0930\u0924\u093f\u092d\u093e\u0936\u093e\u0932\u0940 \u0939\u0948, \u0932\u0947\u0915\u093f\u0928 \u0909\u0938\u0947 \u0930\u0916\u0928\u0947 \u0938\u0947 \u0906\u092a\u0915\u0940 \u0938\u094d\u0925\u093f\u0924\u093f \u0916\u0924\u0930\u0947 \u092e\u0947\u0902 \u092a\u0921\u093c \u0938\u0915\u0924\u0940 \u0939\u0948\u0964", "left": "\u0928\u093f\u0937\u094d\u092a\u0915\u094d\u0937 \u0930\u0942\u092a \u0938\u0947 \u092e\u0942\u0932\u094d\u092f\u093e\u0902\u0915\u0928 \u0915\u0930\u0947\u0902 \u0914\u0930 \u092a\u094d\u0930\u0924\u093f\u092d\u093e\u0936\u093e\u0932\u0940 \u0915\u094b \u0938\u093f\u092b\u093e\u0930\u093f\u0936 \u0915\u0930\u0947\u0902", "right": "\u091b\u094b\u091f\u0940 \u0915\u092e\u093f\u092f\u094b\u0902 \u0915\u094b \u092c\u0922\u093c\u093e-\u091a\u0922\u093c\u093e\u0915\u0930 \u0905\u0938\u094d\u0935\u0940\u0915\u093e\u0930 \u0915\u0930\u0947\u0902 \u0914\u0930 \u0905\u092a\u0928\u0940 \u0938\u094d\u0925\u093f\u0924\u093f \u092c\u091a\u093e\u090f\u0902" },
        "d2": { "scenario": "\u0915\u0930\u0940\u092c\u0940 \u0926\u094b\u0938\u094d\u0924 \u0928\u0947 \u0906\u092a\u0915\u094b \u090f\u0915 \u092c\u0921\u093c\u093e \u0930\u093e\u091c\u093c \u092c\u0924\u093e\u092f\u093e\u0964 \u0907\u0938 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u0938\u0947 \u0906\u092a\u0915\u094b \u092a\u094d\u0930\u094b\u092e\u094b\u0936\u0928 \u092e\u093f\u0932 \u0938\u0915\u0924\u0940 \u0939\u0948\u0964", "left": "\u0930\u093e\u091c\u093c \u0930\u0916\u0947\u0902 \u0914\u0930 \u0926\u094b\u0938\u094d\u0924 \u0915\u0947 \u0935\u093f\u0936\u094d\u0935\u093e\u0938 \u0915\u093e \u0938\u092e\u094d\u092e\u093e\u0928 \u0915\u0930\u0947\u0902", "right": "\u0938\u0942\u0915\u094d\u0937\u094d\u092e \u0930\u0942\u092a \u0938\u0947 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930 \u0905\u0935\u0938\u0930 \u092c\u0928\u093e\u090f\u0902" },
        "d3": { "scenario": "\u090f\u0915 \u092c\u0947\u0915\u093e\u092c\u0942 \u0938\u094d\u0935\u091a\u093e\u0932\u093f\u0924 \u0915\u093e\u0930 5 \u0932\u094b\u0917\u094b\u0902 \u0915\u0940 \u0913\u0930 \u091c\u093e \u0930\u0939\u0940 \u0939\u0948\u0964 \u092c\u091f\u0928 \u0926\u092c\u093e\u0928\u0947 \u0938\u0947 \u0926\u093f\u0936\u093e \u092c\u0926\u0932 \u0938\u0915\u0924\u0940 \u0939\u0948, \u0932\u0947\u0915\u093f\u0928 1 \u0935\u094d\u092f\u0915\u094d\u0924\u093f \u0915\u094b \u091a\u094b\u091f \u0932\u0917\u0947\u0917\u0940\u0964", "left": "\u0915\u0941\u091b \u0928 \u0915\u0930\u0947\u0902\u0964 \u0938\u0940\u0927\u0947 \u0939\u093e\u0925 \u0928 \u0917\u0902\u0926\u0947 \u0915\u0930\u0947\u0902", "right": "\u092c\u091f\u0928 \u0926\u092c\u093e\u090f\u0902\u0964 1 \u0915\u0940 \u0915\u0941\u0930\u094d\u092c\u093e\u0928\u0940 \u0938\u0947 5 \u0915\u094b \u092c\u091a\u093e\u090f\u0902" },
        "d4": { "scenario": "\u0906\u092a\u0915\u0940 \u091f\u0940\u092e \u0928\u0947 \u090f\u0915 \u092c\u0921\u093c\u0940 \u092a\u0930\u093f\u092f\u094b\u091c\u0928\u093e \u092a\u0942\u0930\u0940 \u0915\u0940\u0964 \u092c\u0949\u0938 \u092a\u0942\u091b\u0924\u093e \u0939\u0948 \u0915\u093f\u0938\u0928\u0947 \u0938\u092c\u0938\u0947 \u0905\u0927\u093f\u0915 \u092f\u094b\u0917\u0926\u093e\u0928 \u0926\u093f\u092f\u093e\u0964", "left": "\u0938\u092d\u0940 \u0915\u0947 \u092f\u094b\u0917\u0926\u093e\u0928 \u0915\u094b \u0908\u092e\u093e\u0928\u0926\u093e\u0930\u0940 \u0938\u0947 \u092c\u0924\u093e\u090f\u0902", "right": "\u0905\u092a\u0928\u0947 \u0928\u0947\u0924\u0943\u0924\u094d\u0935 \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902 \u092a\u0947\u0936 \u0915\u0930\u0947\u0902 \u0914\u0930 \u0936\u093e\u0928 \u0932\u0947\u0902" },
        "d5": { "scenario": "\u0911\u0928\u0932\u093e\u0907\u0928 \u0917\u0947\u092e \u092e\u0947\u0902 \u092a\u094d\u0930\u0924\u093f\u0926\u094d\u0935\u0902\u0926\u094d\u0935\u0940 \u0928\u0947 \u0917\u0932\u0924\u0940 \u0938\u0947 \u0905\u092a\u0928\u0940 \u0915\u092e\u091c\u094b\u0930\u0940 \u0909\u091c\u093e\u0917\u0930 \u0915\u0930 \u0926\u0940\u0964 \u0907\u0938\u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0928\u0947 \u0938\u0947 \u0906\u0938\u093e\u0928 \u091c\u0940\u0924 \u092e\u093f\u0932\u0947\u0917\u0940\u0964", "left": "\u0928\u093f\u0937\u094d\u092a\u0915\u094d\u0937 \u0930\u0942\u092a \u0938\u0947 \u0916\u0947\u0932\u0947\u0902 \u0914\u0930 \u0917\u0932\u0924\u0940 \u0915\u094b \u0928\u091c\u0930\u0905\u0902\u0926\u093e\u091c \u0915\u0930\u0947\u0902", "right": "\u0915\u092e\u091c\u094b\u0930\u0940 \u0915\u093e \u092c\u0947\u0930\u0939\u092e\u0940 \u0938\u0947 \u092b\u093e\u092f\u0926\u093e \u0909\u0920\u093e\u090f\u0902 \u0914\u0930 \u0909\u0928\u0915\u0940 \u0939\u093e\u0930 \u0915\u093e \u0906\u0928\u0902\u0926 \u0932\u0947\u0902" },
        "d6": { "scenario": "\u0906\u092a\u0915\u0940 \u0938\u094b\u0936\u0932 \u092e\u0940\u0921\u093f\u092f\u093e \u092a\u094b\u0938\u094d\u091f \u0915\u094b \u0915\u092e \u0927\u094d\u092f\u093e\u0928 \u092e\u093f\u0932\u093e\u0964 \u0926\u094b\u0938\u094d\u0924 \u0915\u0940 \u092a\u094b\u0938\u094d\u091f \u0909\u0938\u0940 \u0938\u092e\u092f \u0935\u093e\u092f\u0930\u0932 \u0939\u094b \u0917\u0908\u0964", "left": "\u0926\u094b\u0938\u094d\u0924 \u0915\u0940 \u0938\u092b\u0932\u0924\u093e \u0915\u0940 \u092c\u0927\u093e\u0908 \u0926\u0947\u0902 \u0914\u0930 \u0905\u092a\u0928\u0940 \u092a\u094b\u0938\u094d\u091f \u092d\u0942\u0932 \u091c\u093e\u090f\u0902", "right": "\u0926\u094b\u0938\u094d\u0924 \u0915\u094b \u092a\u091b\u093e\u0921\u093c\u0928\u0947 \u0935\u093e\u0932\u0940 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u092c\u0928\u093e\u090f\u0902 \u0914\u0930 \u0927\u094d\u092f\u093e\u0928 \u0935\u093e\u092a\u0938 \u0932\u093e\u090f\u0902" },
        "d7": { "scenario": "\u0911\u0921\u093f\u091f \u092e\u0947\u0902 \u0938\u0939\u0915\u0930\u094d\u092e\u0940 \u0915\u0940 \u0935\u093f\u0924\u094d\u0924\u0940\u092f \u0927\u094b\u0916\u093e\u0927\u0921\u093c\u0940 \u0915\u093e \u092a\u0924\u093e \u091a\u0932\u093e\u0964 \u0930\u093f\u092a\u094b\u0930\u094d\u091f \u0915\u0930\u0928\u0947 \u0938\u0947 \u0928\u094c\u0915\u0930\u0940 \u091c\u093e\u090f\u0917\u0940; \u091a\u0941\u092a \u0930\u0939\u0928\u0947 \u092e\u0947\u0902 \u091c\u094b\u0916\u093f\u092e \u0939\u0948\u0964", "left": "\u0924\u0941\u0930\u0902\u0924 \u0930\u093f\u092a\u094b\u0930\u094d\u091f \u0915\u0930\u0947\u0902\u0964 \u0928\u093f\u092f\u092e \u092a\u0939\u0932\u0947", "right": "\u0938\u0939\u0915\u0930\u094d\u092e\u0940 \u0938\u0947 \u090f\u0939\u0938\u093e\u0928 \u0915\u0947 \u092c\u0926\u0932\u0947 \u091a\u0941\u092a \u0930\u0939\u0947\u0902" },
        "d8": { "scenario": "\u092a\u0921\u093c\u094b\u0938\u0940 \u0915\u0947 \u0936\u094b\u0930 \u0938\u0947 \u0939\u092b\u094d\u0924\u094b\u0902 \u0938\u0947 \u0928\u0940\u0902\u0926 \u0928\u0939\u0940\u0902 \u0906 \u0930\u0939\u0940\u0964 \u0935\u094b \u0938\u0939\u092f\u094b\u0917 \u0928\u0939\u0940\u0902 \u0915\u0930\u0924\u0947 \u0914\u0930 \u092a\u094d\u0930\u092c\u0902\u0927\u0928 \u092d\u0940 \u092e\u0926\u0926 \u0928\u0939\u0940\u0902 \u0915\u0930\u0924\u093e\u0964", "left": "\u0927\u0948\u0930\u094d\u092f \u0938\u0947 \u092c\u093e\u0924\u091a\u0940\u0924 \u091c\u093e\u0930\u0940 \u0930\u0916\u0947\u0902 \u092f\u093e \u0918\u0930 \u092c\u0926\u0932\u0928\u0947 \u092a\u0930 \u0935\u093f\u091a\u093e\u0930 \u0915\u0930\u0947\u0902", "right": "\u092a\u0921\u093c\u094b\u0938\u0940 \u0915\u0947 \u0938\u092c\u0938\u0947 \u0905\u0938\u0941\u0935\u093f\u0927\u093e\u091c\u0928\u0915 \u0938\u092e\u092f \u092a\u0930 \u0914\u0930 \u091c\u094b\u0930 \u0938\u0947 \u0936\u094b\u0930 \u092e\u091a\u093e\u0915\u0930 \u092c\u0926\u0932\u093e \u0932\u0947\u0902" },
        "d9": { "scenario": "\u0906\u092a \u091f\u0942\u0930\u094d\u0928\u093e\u092e\u0947\u0902\u091f \u092b\u093e\u0907\u0928\u0932 \u091c\u0940\u0924\u0928\u0947 \u0935\u093e\u0932\u0947 \u0939\u0948\u0902\u0964 \u092a\u094d\u0930\u0924\u093f\u0926\u094d\u0935\u0902\u0926\u094d\u0935\u0940 \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0938\u092e\u0938\u094d\u092f\u093e\u0913\u0902 \u0938\u0947 \u092e\u093e\u0928\u0938\u093f\u0915 \u0930\u0942\u092a \u0938\u0947 \u0905\u0938\u094d\u0925\u093f\u0930 \u0926\u093f\u0916 \u0930\u0939\u093e \u0939\u0948\u0964", "left": "\u0938\u0939\u093e\u0928\u0941\u092d\u0942\u0924\u093f \u0926\u093f\u0916\u093e\u090f\u0902 \u0914\u0930 \u0916\u093f\u0932\u093e\u0921\u093c\u0940 \u092d\u093e\u0935\u0928\u093e \u0938\u0947 \u0916\u0947\u0932\u0947\u0902", "right": "\u0909\u0928\u0915\u0940 \u092d\u093e\u0935\u0928\u093e\u0924\u094d\u092e\u0915 \u0915\u092e\u091c\u094b\u0930\u0940 \u0915\u094b \u0909\u0915\u0938\u093e\u090f\u0902 \u0914\u0930 \u091f\u0942\u091f\u0924\u0947 \u0926\u0947\u0916\u0928\u0947 \u0915\u093e \u0906\u0928\u0902\u0926 \u0932\u0947\u0902" },
        "d10": { "scenario": "\u0906\u092a \u0936\u0939\u0930 \u0915\u0940 \u092c\u091c\u091f \u0938\u092e\u093f\u0924\u093f \u092e\u0947\u0902 \u0939\u0948\u0902\u0964 \u0905\u092a\u0928\u0947 \u0915\u094d\u0937\u0947\u0924\u094d\u0930 \u0915\u094b \u0905\u0927\u093f\u0915 \u0927\u0928 \u0926\u0947 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902, \u0932\u0947\u0915\u093f\u0928 \u0917\u0930\u0940\u092c \u0915\u094d\u0937\u0947\u0924\u094d\u0930 \u0915\u094b \u0928\u0941\u0915\u0938\u093e\u0928 \u0939\u094b\u0917\u093e\u0964", "left": "\u0938\u092c\u0938\u0947 \u0905\u0927\u093f\u0915 \u091c\u0930\u0942\u0930\u0924 \u0915\u0947 \u0906\u0927\u093e\u0930 \u092a\u0930 \u0928\u093f\u0937\u094d\u092a\u0915\u094d\u0937 \u0930\u0942\u092a \u0938\u0947 \u0935\u093f\u0924\u0930\u093f\u0924 \u0915\u0930\u0947\u0902", "right": "\u0905\u092a\u0928\u0947 \u092a\u0915\u094d\u0937 \u092e\u0947\u0902 \u092c\u091c\u091f \u092e\u0947\u0902 \u0939\u0947\u0930\u092b\u0947\u0930 \u0915\u0930\u0947\u0902 \u0914\u0930 \u0909\u0938 \u092a\u094d\u0930\u092d\u093e\u0935 \u0915\u093e \u0906\u0928\u0902\u0926 \u0932\u0947\u0902" }
