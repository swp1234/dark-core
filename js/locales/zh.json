        },
        "q7": {
            "text": "\u6709\u4eba\u5728\u4f60\u524d\u9762\u63d2\u961f",
            "a": "\u7b97\u4e86",
            "b": "\u793c\u8c8c\u5730\u6307\u51fa",
            "c": "\u653b\u51fb\u6027\u5730\u5bf9\u8d28",
            "d": "\u81ea\u5df1\u4e5f\u63d2\u5230\u522b\u4eba\u524d\u9762"
        },
        "q8": {
            "text": "\u4f60\u6361\u5230\u4e86\u4e00\u4e2a\u6709\u73b0\u91d1\u548c\u8eab\u4efd\u8bc1\u7684\u94b1\u5305",
            "a": "\u8fde\u540c\u6240\u6709\u4e1c\u897f\u4e00\u8d77\u5f52\u8fd8",
            "b": "\u5f52\u8fd8\u94b1\u5305\uff0c\u7559\u4e0b\u73b0\u91d1",
            "c": "\u62ff\u8d70\u73b0\u91d1\uff0c\u4e22\u6389\u94b1\u5305",
