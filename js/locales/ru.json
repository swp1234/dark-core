{
    "meta": {
        "title": "\u0422\u0435\u0441\u0442 \u0422\u0451\u043c\u043d\u043e\u0433\u043e \u042f\u0434\u0440\u0430 \u041b\u0438\u0447\u043d\u043e\u0441\u0442\u0438 | DopaBrain",
        "description": "\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0441\u0432\u043e\u0451 \u0442\u0451\u043c\u043d\u043e\u0435 \u044f\u0434\u0440\u043e. \u0418\u0437\u043c\u0435\u0440\u044c\u0442\u0435 \u0447\u0435\u0440\u0442\u044b \u0442\u0451\u043c\u043d\u043e\u0439 \u0442\u0440\u0438\u0430\u0434\u044b: \u041d\u0430\u0440\u0446\u0438\u0441\u0441\u0438\u0437\u043c, \u041c\u0430\u043a\u0438\u0430\u0432\u0435\u043b\u043b\u0438\u0437\u043c, \u041f\u0441\u0438\u0445\u043e\u043f\u0430\u0442\u0438\u044e \u0438 \u0421\u0430\u0434\u0438\u0437\u043c."
    },
    "a11y": {
        "skip": "\u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u043a \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u044e"
    },
    "app": {
        "title": "\u0422\u0435\u0441\u0442 \u0422\u0451\u043c\u043d\u043e\u0433\u043e \u042f\u0434\u0440\u0430",
        "subtitle": "\u041d\u0430\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0442\u0451\u043c\u043d\u0430 \u0432\u0430\u0448\u0430 \u043b\u0438\u0447\u043d\u043e\u0441\u0442\u044c?",
        "description": "\u041e\u0442\u0432\u0435\u0442\u044c\u0442\u0435 \u043d\u0430 12 \u0442\u0451\u043c\u043d\u044b\u0445 \u0441\u0446\u0435\u043d\u0430\u0440\u0438\u0435\u0432, \u0447\u0442\u043e\u0431\u044b \u0440\u0430\u0441\u043a\u0440\u044b\u0442\u044c \u0441\u0432\u043e\u0451 \u0422\u0451\u043c\u043d\u043e\u0435 \u042f\u0434\u0440\u043e. \u0418\u0437\u043c\u0435\u0440\u044c\u0442\u0435 \u041d\u0430\u0440\u0446\u0438\u0441\u0441\u0438\u0437\u043c, \u041c\u0430\u043a\u0438\u0430\u0432\u0435\u043b\u043b\u0438\u0437\u043c, \u041f\u0441\u0438\u0445\u043e\u043f\u0430\u0442\u0438\u044e \u0438 \u0421\u0430\u0434\u0438\u0437\u043c.",
        "start": "\u0420\u0430\u0441\u043a\u0440\u044b\u0442\u044c \u041c\u043e\u0451 \u0422\u0451\u043c\u043d\u043e\u0435 \u042f\u0434\u0440\u043e"
    },
    "quiz": {
        "currentDark": "\u0422\u0451\u043c\u043d\u044b\u0439 \u0421\u0447\u0451\u0442:",
        "progress": "{current} / {total}"
    },
    "traits": {
        "narcissism": "\u041d\u0430\u0440\u0446\u0438\u0441\u0441\u0438\u0437\u043c",
        "machiavellianism": "\u041c\u0430\u043a\u0438\u0430\u0432\u0435\u043b\u043b\u0438\u0437\u043c",
        "psychopathy": "\u041f\u0441\u0438\u0445\u043e\u043f\u0430\u0442\u0438\u044f",
        "sadism": "\u0421\u0430\u0434\u0438\u0437\u043c"
    },
    "questions": {
        "q1": {
            "text": "\u0414\u0440\u0443\u0433 \u0434\u043e\u0441\u0442\u0438\u0433 \u0442\u043e\u0433\u043e, \u0447\u0435\u0433\u043e \u0432\u044b \u0432\u0441\u0435\u0433\u0434\u0430 \u0445\u043e\u0442\u0435\u043b\u0438",
            "a": "\u0418\u0441\u043a\u0440\u0435\u043d\u043d\u0435 \u043f\u043e\u0440\u0430\u0434\u043e\u0432\u0430\u0442\u044c\u0441\u044f",
            "b": "\u041f\u043e\u0437\u0434\u0440\u0430\u0432\u0438\u0442\u044c, \u043d\u043e \u043f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0437\u0430\u0432\u0438\u0441\u0442\u044c",
            "c": "\u041f\u0440\u0435\u0443\u043c\u0435\u043d\u044c\u0448\u0438\u0442\u044c \u0438\u0445 \u0434\u043e\u0441\u0442\u0438\u0436\u0435\u043d\u0438\u0435",
            "d": "\u041f\u043e\u043f\u044b\u0442\u0430\u0442\u044c\u0441\u044f \u0441\u0440\u0430\u0437\u0443 \u043f\u0440\u0435\u0432\u0437\u043e\u0439\u0442\u0438"
        },
        "q2": {
            "text": "\u0412\u044b \u0437\u0430\u043c\u0435\u0447\u0430\u0435\u0442\u0435 \u0441\u0432\u043e\u0451 \u043e\u0442\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0432 \u0432\u0438\u0442\u0440\u0438\u043d\u0435",
            "a": "\u041f\u0440\u043e\u0439\u0442\u0438 \u043c\u0438\u043c\u043e, \u043d\u0435 \u0437\u0430\u043c\u0435\u0442\u0438\u0432",
            "b": "\u0411\u044b\u0441\u0442\u0440\u044b\u0439 \u0432\u0437\u0433\u043b\u044f\u0434 \u0438 \u0434\u0430\u043b\u044c\u0448\u0435",
            "c": "\u041e\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u044c\u0441\u044f \u043f\u043e\u043b\u044e\u0431\u043e\u0432\u0430\u0442\u044c\u0441\u044f",
            "d": "\u0421\u0434\u0435\u043b\u0430\u0442\u044c \u0441\u0435\u043b\u0444\u0438 \u043f\u0440\u044f\u043c\u043e \u0442\u0430\u043c"
        },
        "q3": {
            "text": "\u041a\u0442\u043e-\u0442\u043e \u043f\u0443\u0431\u043b\u0438\u0447\u043d\u043e \u043a\u0440\u0438\u0442\u0438\u043a\u0443\u0435\u0442 \u0432\u0430\u0448\u0443 \u0440\u0430\u0431\u043e\u0442\u0443",
            "a": "\u041f\u0440\u0438\u043d\u044f\u0442\u044c \u043e\u0431\u0440\u0430\u0442\u043d\u0443\u044e \u0441\u0432\u044f\u0437\u044c \u0434\u043e\u0441\u0442\u043e\u0439\u043d\u043e",
            "b": "\u0412\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435 \u0437\u0430\u0449\u0438\u0449\u0430\u0442\u044c\u0441\u044f",
            "c": "\u0417\u0430\u043c\u044b\u0441\u043b\u0438\u0442\u044c \u0440\u0430\u0437\u043e\u0431\u043b\u0430\u0447\u0435\u043d\u0438\u0435 \u0438\u0445 \u043d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043a\u043e\u0432",
            "d": "\u041f\u0443\u0431\u043b\u0438\u0447\u043d\u043e \u0443\u043d\u0438\u0437\u0438\u0442\u044c \u0432 \u043e\u0442\u0432\u0435\u0442"
        },
        "q4": {
            "text": "\u0412\u044b \u0443\u0437\u043d\u0430\u043b\u0438 \u0441\u0435\u043a\u0440\u0435\u0442 \u043a\u043e\u043b\u043b\u0435\u0433\u0438",
            "a": "\u0421\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c \u0432 \u0442\u0430\u0439\u043d\u0435",
            "b": "\u0417\u0430\u043f\u043e\u043c\u043d\u0438\u0442\u044c \u043f\u0440\u043e \u0441\u0435\u0431\u044f",
            "c": "\u0422\u043e\u043d\u043a\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0434\u043b\u044f \u0440\u0430\u0441\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u044f",
            "d": "\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0434\u043b\u044f \u043f\u043e\u0432\u044b\u0448\u0435\u043d\u0438\u044f"
        },
        "q5": {
            "text": "\u0413\u0440\u0443\u043f\u043f\u043e\u0432\u043e\u043c\u0443 \u043f\u0440\u043e\u0435\u043a\u0442\u0443 \u043d\u0443\u0436\u0435\u043d \u043b\u0438\u0434\u0435\u0440",
            "a": "\u041f\u043e\u0434\u0434\u0435\u0440\u0436\u0430\u0442\u044c \u0434\u043e\u0431\u0440\u043e\u0432\u043e\u043b\u044c\u0446\u0430",
            "b": "\u0412\u044b\u0437\u0432\u0430\u0442\u044c\u0441\u044f, \u0435\u0441\u043b\u0438 \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0445\u043e\u0447\u0435\u0442",
            "c": "\u041c\u0430\u043d\u0438\u043f\u0443\u043b\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0433\u043e\u043b\u043e\u0441\u043e\u0432\u0430\u043d\u0438\u0435\u043c \u0432 \u0441\u0432\u043e\u044e \u043f\u043e\u043b\u044c\u0437\u0443",
            "d": "\u0421\u0430\u0431\u043e\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0434\u0440\u0443\u0433\u0438\u0445 \u043a\u0430\u043d\u0434\u0438\u0434\u0430\u0442\u043e\u0432"
        },
        "q6": {
            "text": "\u041c\u043e\u0436\u043d\u043e \u043f\u0440\u043e\u0434\u0432\u0438\u043d\u0443\u0442\u044c\u0441\u044f, \u043d\u0430\u0440\u0443\u0448\u0438\u0432 \u043f\u0440\u0430\u0432\u0438\u043b\u0430",
            "a": "\u0421\u0442\u0440\u043e\u0433\u043e \u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c \u043f\u0440\u0430\u0432\u0438\u043b\u0430\u043c",
            "b": "\u0421\u043b\u0435\u0433\u043a\u0430 \u043d\u0430\u0440\u0443\u0448\u0438\u0442\u044c, \u0435\u0441\u043b\u0438 \u0431\u0435\u0437\u0432\u0440\u0435\u0434\u043d\u043e",
            "c": "\u041d\u0430\u0440\u0443\u0448\u0430\u0442\u044c, \u0435\u0441\u043b\u0438 \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0432\u0438\u0434\u0438\u0442",
            "d": "\u041f\u0440\u0430\u0432\u0438\u043b\u0430 \u2014 \u044d\u0442\u043e \u043f\u0440\u043e\u0441\u0442\u043e \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f"
        },
        "q7": {
            "text": "\u041a\u0442\u043e-\u0442\u043e \u043b\u0435\u0437\u0435\u0442 \u0432 \u043e\u0447\u0435\u0440\u0435\u0434\u044c \u043f\u0435\u0440\u0435\u0434 \u0432\u0430\u043c\u0438",
            "a": "\u041e\u0442\u043f\u0443\u0441\u0442\u0438\u0442\u044c",
            "b": "\u0412\u0435\u0436\u043b\u0438\u0432\u043e \u0443\u043a\u0430\u0437\u0430\u0442\u044c",
            "c": "\u0410\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043d\u043e \u043f\u0440\u043e\u0442\u0438\u0432\u043e\u0441\u0442\u043e\u044f\u0442\u044c",
            "d": "\u0421\u0430\u043c\u043e\u043c\u0443 \u0432\u043b\u0435\u0437\u0442\u044c \u043f\u0435\u0440\u0435\u0434 \u043a\u0435\u043c-\u0442\u043e"
        },
        "q8": {
            "text": "\u0412\u044b \u043d\u0430\u0445\u043e\u0434\u0438\u0442\u0435 \u043a\u043e\u0448\u0435\u043b\u0451\u043a \u0441 \u0434\u0435\u043d\u044c\u0433\u0430\u043c\u0438 \u0438 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u043c\u0438",
            "a": "\u0412\u0435\u0440\u043d\u0443\u0442\u044c \u0432\u0441\u0451",
            "b": "\u0412\u0435\u0440\u043d\u0443\u0442\u044c, \u043e\u0441\u0442\u0430\u0432\u0438\u0432 \u0434\u0435\u043d\u044c\u0433\u0438",
            "c": "\u0412\u0437\u044f\u0442\u044c \u0434\u0435\u043d\u044c\u0433\u0438, \u0432\u044b\u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043a\u043e\u0448\u0435\u043b\u0451\u043a",
            "d": "\u0417\u0430\u0431\u0440\u0430\u0442\u044c \u0432\u0441\u0451 \u0431\u0435\u0437 \u0443\u0433\u0440\u044b\u0437\u0435\u043d\u0438\u0439 \u0441\u043e\u0432\u0435\u0441\u0442\u0438"
        },
        "q9": {
            "text": "\u041d\u0435\u0437\u043d\u0430\u043a\u043e\u043c\u0435\u0446 \u0441\u0442\u0440\u0443\u0433\u0433\u043b\u0438\u0442\u0441\u044f \u0441 \u0442\u044f\u0436\u0451\u043b\u044b\u043c\u0438 \u0441\u0443\u043c\u043a\u0430\u043c\u0438",
            "a": "\u0421\u0440\u0430\u0437\u0443 \u043f\u043e\u043c\u043e\u0447\u044c",
            "b": "\u041f\u043e\u043c\u043e\u0447\u044c, \u0435\u0441\u043b\u0438 \u0443\u0434\u043e\u0431\u043d\u043e",
            "c": "\u041f\u0440\u043e\u0439\u0442\u0438 \u043c\u0438\u043c\u043e, \u043d\u0435 \u0432\u0430\u0448\u0430 \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u0430",
            "d": "\u041d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u0442\u044c\u0441\u044f, \u043d\u0430\u0431\u043b\u044e\u0434\u0430\u044f \u0437\u0430 \u0438\u0445 \u043c\u0443\u0447\u0435\u043d\u0438\u0435\u043c"
        },
        "q10": {
            "text": "\u0412\u0430\u0448 \u0441\u043e\u043f\u0435\u0440\u043d\u0438\u043a \u043f\u0440\u043e\u0432\u0430\u043b\u0438\u043b\u0441\u044f \u0432 \u0432\u0430\u0436\u043d\u043e\u043c \u0434\u0435\u043b\u0435",
            "a": "\u041f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0441\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0435",
            "b": "\u041e\u0441\u0442\u0430\u0442\u044c\u0441\u044f \u043d\u0435\u0439\u0442\u0440\u0430\u043b\u044c\u043d\u044b\u043c",
            "c": "\u041f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u043b\u0451\u0433\u043a\u043e\u0435 \u0443\u0434\u043e\u0432\u043b\u0435\u0442\u0432\u043e\u0440\u0435\u043d\u0438\u0435",
            "d": "\u0418\u0441\u043a\u0440\u0435\u043d\u043d\u0435 \u043e\u0431\u0440\u0430\u0434\u043e\u0432\u0430\u0442\u044c\u0441\u044f"
        },
        "q11": {
            "text": "\u0412\u044b \u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0432 \u0441\u043e\u0440\u0435\u0432\u043d\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u0443\u044e \u0438\u0433\u0440\u0443",
            "a": "\u0418\u0433\u0440\u0430\u0442\u044c \u0447\u0435\u0441\u0442\u043d\u043e, \u0433\u043b\u0430\u0432\u043d\u043e\u0435 \u2014 \u0443\u0434\u043e\u0432\u043e\u043b\u044c\u0441\u0442\u0432\u0438\u0435",
            "b": "\u041f\u044b\u0442\u0430\u0442\u044c\u0441\u044f \u043f\u043e\u0431\u0435\u0434\u0438\u0442\u044c \u043f\u043e \u043f\u0440\u0430\u0432\u0438\u043b\u0430\u043c",
            "c": "\u041f\u0441\u0438\u0445\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438 \u0434\u0430\u0432\u0438\u0442\u044c \u0441\u043e\u043f\u0435\u0440\u043d\u0438\u043a\u043e\u0432",
            "d": "\u041d\u0430\u0441\u043b\u0430\u0436\u0434\u0430\u0442\u044c\u0441\u044f \u0441\u043e\u043a\u0440\u0443\u0448\u0435\u043d\u0438\u0435\u043c \u0434\u0443\u0445\u0430 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u043e\u0432"
        },
        "q12": {
            "text": "\u0417\u043b\u043e\u0434\u0435\u0439 \u0432 \u0444\u0438\u043b\u044c\u043c\u0435 \u043e\u0431\u044a\u044f\u0441\u043d\u044f\u0435\u0442 \u0441\u0432\u043e\u0439 \u0437\u043b\u043e\u0432\u0435\u0449\u0438\u0439 \u043f\u043b\u0430\u043d",
            "a": "\u0411\u043e\u043b\u0435\u0442\u044c \u0437\u0430 \u0433\u0435\u0440\u043e\u044f",
            "b": "\u041f\u043e\u043d\u044f\u0442\u044c \u043b\u043e\u0433\u0438\u043a\u0443 \u0437\u043b\u043e\u0434\u0435\u044f",
            "c": "\u0412\u043e\u0441\u0445\u0438\u0442\u0438\u0442\u044c\u0441\u044f \u0438\u043d\u0442\u0435\u043b\u043b\u0435\u043a\u0442\u043e\u043c \u0437\u043b\u043e\u0434\u0435\u044f",
            "d": "\u0425\u043e\u0442\u0435\u0442\u044c \u0432\u043e\u043f\u043b\u043e\u0442\u0438\u0442\u044c \u044d\u0442\u043e\u0442 \u043f\u043b\u0430\u043d"
        }
    },
    "tiers": {
