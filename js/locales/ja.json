            "b": "\u795d\u3046\u304c\u5acc\u59ac\u3092\u611f\u3058\u308b",
            "c": "\u5f7c\u3089\u306e\u6210\u679c\u3092\u904e\u5c0f\u8a55\u4fa1\u3059\u308b",
            "d": "\u3059\u3050\u306b\u8d85\u3048\u3088\u3046\u3068\u3059\u308b"
        },
        "q2": {
            "text": "\u5e97\u306e\u30a6\u30a3\u30f3\u30c9\u30a6\u306b\u81ea\u5206\u306e\u59ff\u304c\u6620\u3063\u3066\u3044\u308b",
            "a": "\u6c17\u3065\u304b\u305a\u901a\u308a\u904e\u304e\u308b",
            "b": "\u3061\u3089\u3063\u3068\u898b\u3066\u901a\u308a\u904e\u304e\u308b",
            "c": "\u7acb\u3061\u6b62\u307e\u3063\u3066\u81ea\u5206\u3092\u7709\u3081\u308b",
            "d": "\u305d\u306e\u5834\u3067\u81ea\u64ae\u308a\u3059\u308b"
        },
        "q3": {
            "text": "\u8ab0\u304b\u304c\u516c\u306e\u5834\u3067\u3042\u306a\u305f\u306e\u4ed5\u4e8b\u3092\u6279\u5224\u3057\u305f",
            "a": "\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af\u3092\u4e01\u5be7\u306b\u53d7\u3051\u5165\u308c\u308b",
            "b": "\u5185\u5fc3\u3067\u306f\u9632\u5fa1\u7684\u306b\u306a\u308b",
            "c": "\u76f8\u624b\u306e\u6b20\u70b9\u3092\u66b4\u304f\u8a08\u753b\u3092\u7acb\u3066\u308b",
            "d": "\u516c\u306b\u76f8\u624b\u3092\u8fb1\u3081\u8fd4\u3059"
        },
        "q4": {
            "text": "\u540c\u50da\u306e\u79d8\u5bc6\u3092\u77e5\u3063\u3066\u3057\u307e\u3063\u305f",
            "a": "\u79d8\u5bc6\u3092\u5b88\u308b",
            "b": "\u8907\u306b\u8a18\u61b6\u3057\u3066\u304a\u304f",
            "c": "\u3055\u308a\u3052\u306a\u304f\u5229\u7528\u3057\u3066\u597d\u611f\u3092\u5f97\u308b",
            "d": "\u6607\u9032\u306e\u305f\u3081\u306b\u5229\u7528\u3059\u308b"
        },
        "q5": {
            "text": "\u30b0\u30eb\u30fc\u30d7\u30d7\u30ed\u30b8\u30a7\u30af\u30c8\u306b\u30ea\u30fc\u30c0\u30fc\u304c\u5fc5\u8981\u3060",
            "a": "\u5fd7\u9858\u3059\u308b\u4eba\u3092\u652f\u6301\u3059\u308b",
            "b": "\u8ab0\u3082\u3044\u306a\u3051\u308c\u3070\u5fd7\u9858\u3059\u308b",
            "c": "\u6295\u7968\u3092\u64cd\u4f5c\u3057\u3066\u81ea\u5206\u306b\u6709\u5229\u306b\u3059\u308b",
            "d": "\u4ed6\u306e\u5019\u88dc\u3092\u59a8\u5bb3\u3059\u308b"
