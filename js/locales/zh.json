            "c": "\u8d2c\u4f4e\u4ed6\u4eec\u7684\u6210\u5c31",
            "d": "\u7acb\u523b\u8bd5\u56fe\u8d85\u8d8a\u4ed6\u4eec"
        },
        "q2": {
            "text": "\u4f60\u5728\u5546\u5e97\u6a96\u7a97\u4e2d\u770b\u5230\u81ea\u5df1\u7684\u5012\u5f71",
            "a": "\u6ca1\u6ce8\u610f\u5c31\u8d70\u8fc7\u4e86",
            "b": "\u77ac\u4e00\u773c\u7ee7\u7eed\u8d70",
            "c": "\u505c\u4e0b\u6765\u6b23\u8d4f\u81ea\u5df1",
            "d": "\u5f53\u573a\u81ea\u62cd"
        },
        "q3": {
            "text": "\u6709\u4eba\u5f53\u4f17\u6279\u8bc4\u4f60\u7684\u5de5\u4f5c",
            "a": "\u4f18\u96c5\u5730\u63a5\u53d7\u53cd\u9988",
            "b": "\u5185\u5fc3\u53d8\u5f97\u9632\u5fa1",
            "c": "\u8ba1\u5212\u63ed\u9732\u4ed6\u4eec\u7684\u7f3a\u70b9",
            "d": "\u5f53\u4f17\u7f9e\u8fb1\u56de\u53bb"
        },
        "q4": {
            "text": "\u4f60\u53d1\u73b0\u4e86\u540c\u4e8b\u7684\u79d8\u5bc6",
            "a": "\u4fdd\u5b88\u79d8\u5bc6",
            "b": "\u5728\u5fc3\u91cc\u8bb0\u4e0b",
            "c": "\u5de7\u5999\u5229\u7528\u5b83\u6765\u83b7\u5f97\u597d\u611f",
            "d": "\u5229\u7528\u5b83\u6765\u5347\u804c"
        },
        "q5": {
            "text": "\u56e2\u961f\u9879\u76ee\u9700\u8981\u4e00\u4e2a\u9886\u5bfc\u8005",
            "a": "\u652f\u6301\u81ea\u613f\u7684\u4eba",
            "b": "\u6ca1\u4eba\u5fd7\u613f\u5c31\u81ea\u5df1\u4e0a",
            "c": "\u64cd\u7eb5\u6295\u7968\u5bf9\u81ea\u5df1\u6709\u5229",
            "d": "\u7834\u574f\u5176\u4ed6\u5019\u9009\u4eba"
        },
        "q6": {
            "text": "\u8fdd\u89c4\u53ef\u4ee5\u8ba9\u4f60\u9886\u5148",
            "a": "\u4e25\u683c\u9075\u5b88\u89c4\u5219",
            "b": "\u65e0\u5bb3\u7684\u8bdd\u7a0d\u5fae\u8fdd\u89c4",
